---
const benefits = [
  {
    title: 'New revenue stream',
    description: 'Earn on every Pix transaction your merchants process',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h.01"/><path d="M7 20v-4"/><path d="M12 20v-8"/><path d="M17 20V8"/><path d="M22 4v16"/></svg>',
  },
  {
    title: 'Zero operational complexity',
    description: 'We handle compliance, settlement, and FX — you just integrate once',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>',
  },
  {
    title: 'Merchant differentiation',
    description: 'Help your merchants capture a market segment their competitors are missing',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>',
  },
  {
    title: 'Fast go-to-market',
    description: 'API-first architecture means you can be live in weeks, not months',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m13 2 5.464 5.464a1 1 0 0 1 0 1.414L7.636 19.707a1 1 0 0 1-1.414 0L2 15.464"/><path d="m8 10 4 4"/><path d="m22 2-8.293 8.293"/></svg>',
  },
];
---

<section id="partners" class="relative py-16 sm:py-24 md:py-32">
  <div class="orb-cyan absolute top-0 left-0 -translate-x-1/3"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Left: content -->
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-xs text-brand-primary mb-6">
          Partner Programme
        </div>
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-heading font-bold leading-tight mb-6">
          Turn Latin American Payments<br />
          <span class="text-gradient-brand">Into a Revenue Engine</span>
        </h2>
        <p class="text-lg text-text-secondary leading-relaxed mb-4">
          If you're a payment service provider, acquirer, or technology platform, epagpos gives you a turnkey way to offer Pix and local APMs to your merchant base — without building anything from scratch.
        </p>
        <p class="text-text-secondary leading-relaxed">
          Whether you serve 10 merchants or 10,000, epagpos scales with you. Let's build the future of cross-border payments together.
        </p>
      </div>

      <!-- Right: benefits grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {benefits.map((benefit) => (
          <div class="glass-card p-5 rounded-xl group hover:border-brand-primary/20 transition-all duration-normal cursor-default">
            <div class="w-10 h-10 rounded-lg bg-brand-primary/10 text-brand-primary flex items-center justify-center mb-3 group-hover:shadow-glow-sm transition-shadow duration-normal" set:html={benefit.icon} />
            <h3 class="text-sm font-heading font-semibold text-text-primary mb-1">{benefit.title}</h3>
            <p class="text-text-secondary text-xs leading-relaxed">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
