---
const steps = [
  {
    number: '1',
    title: 'Customer selects Pix at checkout',
    description: 'A dynamic QR code is generated instantly, displaying the amount in the customer\'s local currency.',
    visual: 'qr-code',
  },
  {
    number: '2',
    title: 'Customer scans and pays from their banking app',
    description: 'One tap. No card numbers, no OTPs, no friction. The payment is authorised in under two seconds.',
    visual: 'scan',
  },
  {
    number: '3',
    title: 'Payment confirmed — sale complete',
    description: 'Both merchant and customer receive instant confirmation. No pending status, no waiting. Done.',
    visual: 'check',
  },
];
---

<section class="relative py-16 sm:py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-10 sm:mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-xs text-brand-primary mb-6">
        See It in Action
      </div>
      <h2 class="text-2xl sm:text-3xl md:text-5xl font-heading font-bold leading-tight">
        A Seamless Payment<br />
        <span class="text-gradient-brand">in Three Seconds</span>
      </h2>
      <p class="mt-6 text-lg text-text-secondary leading-relaxed">
        Here's what your customer's experience looks like — from checkout to confirmation, in real time.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Connecting line -->
      <div class="hidden md:block absolute top-1/2 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-primary/30 to-transparent -translate-y-1/2"></div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {steps.map((step) => (
          <div class="relative">
            <!-- Step card -->
            <div class="glass-card p-8 rounded-2xl text-center h-full">
              <!-- Animated visual placeholder -->
              <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-brand-primary/10 border border-brand-primary/20 flex items-center justify-center">
                {step.visual === 'qr-code' && (
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-primary" aria-hidden="true"><rect width="5" height="5" x="3" y="3" rx="1"/><rect width="5" height="5" x="16" y="3" rx="1"/><rect width="5" height="5" x="3" y="16" rx="1"/><path d="M21 16h-3a2 2 0 0 0-2 2v3"/><path d="M21 21v.01"/><path d="M12 7v3a2 2 0 0 1-2 2H7"/><path d="M3 12h.01"/><path d="M12 3h.01"/><path d="M12 16v.01"/><path d="M16 12h1"/><path d="M21 12v.01"/><path d="M12 21v-1"/></svg>
                )}
                {step.visual === 'scan' && (
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-primary" aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h.01"/><path d="M17 7h.01"/><path d="M7 17h.01"/><path d="M17 17h.01"/><line x1="3" x2="21" y1="12" y2="12"/></svg>
                )}
                {step.visual === 'check' && (
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-status-success" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                )}
              </div>

              <!-- Step number -->
              <div class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-brand-primary text-white text-sm font-heading font-bold mb-4">
                {step.number}
              </div>

              <h3 class="text-lg font-heading font-semibold text-text-primary mb-3">{step.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
