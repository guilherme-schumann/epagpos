---
const features = [
  {
    text: 'Fully regulated and licensed for cross-border payment operations',
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>',
  },
  {
    text: 'End-to-end encryption on every transaction',
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>',
  },
  {
    text: 'Real-time fraud monitoring and risk management',
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>',
  },
  {
    text: 'Transparent FX rates with no hidden markups',
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
  },
  {
    text: 'Dedicated support and onboarding for merchants and partners',
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  },
];
---

<section id="security" class="relative py-16 sm:py-24 md:py-32 bg-surface-raised">
  <div class="bg-line-pattern absolute inset-0 pointer-events-none"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <!-- Section header -->
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-xs text-brand-primary mb-6">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-primary" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
      Trust & Security
    </div>
    <h2 class="text-2xl sm:text-3xl md:text-5xl font-heading font-bold leading-tight mb-6">
      Enterprise-Grade Security.<br />
      <span class="text-gradient-brand">Full Regulatory Compliance.</span>
    </h2>
    <p class="text-lg text-text-secondary leading-relaxed mb-12">
      Cross-border payments demand the highest standards of security and compliance. epagpos is built to meet them.
    </p>

    <!-- Feature list -->
    <div class="glass-card p-6 sm:p-8 md:p-10 rounded-2xl text-left max-w-2xl mx-auto">
      <ul class="space-y-5">
        {features.map((feature) => (
          <li class="flex items-start gap-4">
            <div class="shrink-0 w-10 h-10 rounded-lg bg-brand-primary/10 text-brand-primary flex items-center justify-center" set:html={feature.icon} />
            <span class="text-text-primary pt-2">{feature.text}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
