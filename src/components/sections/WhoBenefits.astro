---
const industries = [
  {
    name: 'Retail & Luxury',
    description: 'Accept Pix in-store and online from high-spending Brazilian and LATAM tourists. Increase basket size with seamless local payments.',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><path d="M15 22v-4a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2v4"/><rect width="20" height="5" x="2" y="7"/></svg>',
  },
  {
    name: 'Hospitality & Travel',
    description: 'Let guests pay for reservations, upgrades, and on-property purchases using the payment method they trust most.',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8c0 4.5-6 9-6 9s-6-4.5-6-9a6 6 0 0 1 12 0"/><circle cx="12" cy="8" r="2"/><path d="M8.835 14H5a1 1 0 0 0-.9.7l-2 6c-.1.1-.1.2-.1.3 0 .6.4 1 1 1h18c.6 0 1-.4 1-1 0-.1 0-.2-.1-.3l-2-6a1 1 0 0 0-.9-.7h-3.835"/></svg>',
  },
  {
    name: 'E-Commerce',
    description: 'Reduce cart abandonment by offering Pix at checkout. Instant confirmation means faster fulfilment.',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>',
  },
  {
    name: 'Marketplaces & Platforms',
    description: 'Enable your sellers to accept Latin American payments and expand your total addressable market overnight.',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>',
  },
  {
    name: 'SaaS & Digital Services',
    description: 'Convert more free-to-paid users across LATAM with local payment options that eliminate card declines.',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>',
  },
];
---

<section id="benefits" class="relative py-16 sm:py-24 md:py-32 bg-surface-raised">
  <div class="bg-dot-pattern absolute inset-0 pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-10 sm:mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-xs text-brand-primary mb-6">
        Who Benefits
      </div>
      <h2 class="text-2xl sm:text-3xl md:text-5xl font-heading font-bold leading-tight">
        Built for Businesses That<br />
        <span class="text-gradient-brand">Serve Global Consumers</span>
      </h2>
      <p class="mt-6 text-lg text-text-secondary leading-relaxed">
        epagpos is designed for any business that wants to capture Latin American demand — whether you're a multinational retailer or a boutique hotel.
      </p>
    </div>

    <!-- Industry cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {industries.map((industry) => (
        <div class="glass-card p-6 rounded-2xl group hover:border-brand-primary/20 transition-all duration-normal cursor-default">
          <div class="flex items-center gap-4 mb-4">
            <div class="shrink-0 w-12 h-12 rounded-xl bg-brand-primary/10 text-brand-primary flex items-center justify-center group-hover:shadow-glow-sm transition-shadow duration-normal" set:html={industry.icon} />
            <h3 class="text-lg font-heading font-semibold text-text-primary">{industry.name}</h3>
          </div>
          <p class="text-text-secondary text-sm leading-relaxed">{industry.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
