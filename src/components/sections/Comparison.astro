---
const rows = [
  { metric: 'Customer fees', cards: '~8.0%', pix: '~3.3%', pixWin: true },
  { metric: 'Total paid by customer', cards: '\u20AC108.00', pix: '\u20AC103.38', pixWin: true },
  { metric: 'Merchant processing fee', cards: '2.65%', pix: '0.9%', pixWin: true },
  { metric: 'Merchant net received', cards: '\u20AC97.30', pix: '\u20AC99.10', pixWin: true },
  { metric: 'Chargeback risk', cards: 'Yes', pix: 'None', pixWin: true },
  { metric: 'Settlement speed', cards: '2\u20135 business days', pix: 'Instant', pixWin: true },
];
---

<section id="comparison" class="relative py-16 sm:py-24 md:py-32">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-10 sm:mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-xs text-brand-primary mb-6">
        Head-to-Head
      </div>
      <h2 class="text-2xl sm:text-3xl md:text-5xl font-heading font-bold leading-tight">
        Why Pix Wins: Cards vs. Pix<br />
        <span class="text-gradient-brand">on a &euro;100 Transaction</span>
      </h2>
      <p class="mt-6 text-lg text-text-secondary leading-relaxed">
        See the real financial impact of accepting Pix versus traditional card networks. On every single transaction, both your customers and your bottom line come out ahead.
      </p>
    </div>

    <!-- Comparison table -->
    <div class="glass-card rounded-2xl overflow-x-auto">
      <div class="min-w-[420px]">
        <!-- Table header -->
        <div class="grid grid-cols-3 bg-surface-card border-b border-border-default">
          <div class="p-3 sm:p-4 md:p-6 text-xs sm:text-sm font-heading font-semibold text-text-secondary">Metric</div>
          <div class="p-3 sm:p-4 md:p-6 text-xs sm:text-sm font-heading font-semibold text-text-secondary text-center">Cards</div>
          <div class="p-3 sm:p-4 md:p-6 text-xs sm:text-sm font-heading font-semibold text-text-accent text-center flex items-center justify-center gap-1 sm:gap-2">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" class="text-brand-primary shrink-0" aria-hidden="true"><path d="M11.917 11.71a2.046 2.046 0 0 1-1.454-.602l-2.1-2.1a.4.4 0 0 0-.551 0l-2.108 2.108a2.044 2.044 0 0 1-1.454.602h-.414l2.66 2.66c.83.83 2.177.83 3.007 0l2.667-2.668h-.253zM4.25 4.282c.55 0 1.066.214 1.454.602l2.108 2.108a.39.39 0 0 0 .552 0l2.1-2.1a2.044 2.044 0 0 1 1.453-.602h.253L9.503 1.623a2.127 2.127 0 0 0-3.007 0l-2.66 2.66h.414z"/><path d="m14.377 6.496-1.612-1.612a.307.307 0 0 1-.114.023h-.733c-.379 0-.75.154-1.017.422l-2.1 2.1a1.005 1.005 0 0 1-1.425 0L5.268 5.32a1.448 1.448 0 0 0-1.018-.422h-.9a.306.306 0 0 1-.109-.021L1.623 6.496c-.83.83-.83 2.177 0 3.008l1.618 1.618a.305.305 0 0 1 .108-.022h.901c.38 0 .75-.153 1.018-.421L7.375 8.57a1.034 1.034 0 0 1 1.426 0l2.1 2.1c.267.268.638.421 1.017.421h.733c.04 0 .079.01.114.024l1.612-1.612c.83-.83.83-2.178 0-3.008z"/></svg>
            Pix
          </div>
        </div>

        <!-- Table rows -->
        {rows.map((row, i) => (
          <div class={`grid grid-cols-3 ${i < rows.length - 1 ? 'border-b border-border-default' : ''} hover:bg-surface-card-hover transition-colors duration-normal`}>
            <div class="p-3 sm:p-4 md:p-6 text-xs sm:text-sm font-medium text-text-primary">{row.metric}</div>
            <div class="p-3 sm:p-4 md:p-6 text-xs sm:text-sm text-text-tertiary text-center">{row.cards}</div>
            <div class="p-3 sm:p-4 md:p-6 text-xs sm:text-sm text-center font-semibold text-status-success">{row.pix}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom callout -->
    <div class="mt-8 glass-card-brand p-6 md:p-8 rounded-2xl text-center">
      <p class="text-text-primary leading-relaxed">
        <strong>The bottom line:</strong> Your customer saves <span class="text-status-success font-semibold">&euro;4.62</span> per transaction. You earn <span class="text-status-success font-semibold">&euro;1.80 more</span> per transaction. Multiply that across thousands of sales, and the impact is transformative.
      </p>
    </div>
  </div>
</section>
