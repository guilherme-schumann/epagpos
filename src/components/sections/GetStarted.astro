---
---

<section id="get-started" class="relative py-20 sm:py-24 md:py-32 overflow-hidden">
  <!-- Background glow -->
  <div class="absolute inset-0 bg-gradient-glow-blue pointer-events-none"></div>
  <div class="orb-blue absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] sm:w-[700px] sm:h-[700px] md:w-[1000px] md:h-[1000px] opacity-40"></div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
    <!-- Section header -->
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-xs text-brand-primary mb-6">
      Get Started
    </div>

    <h2 class="text-2xl sm:text-3xl md:text-5xl font-heading font-bold leading-tight mb-6">
      Ready to Unlock<br />
      <span class="text-gradient-brand">Latin American Revenue?</span>
    </h2>

    <p class="text-base sm:text-lg text-text-secondary leading-relaxed mb-4">
      Start accepting Pix and local payments today.
    </p>
    <p class="text-text-secondary mb-8 sm:mb-10">
      No long contracts. No complex integration. Just new revenue.
    </p>

    <!-- Contact form visual (API integration comes later) -->
    <div data-motion-item class="glass-card-heavy rounded-2xl p-5 sm:p-8 md:p-10 text-left max-w-3xl mx-auto">
      <form class="space-y-5" action="#" method="post" novalidate>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="contact-name" class="block text-sm font-heading font-semibold text-text-primary mb-2">
              Full Name
            </label>
            <input
              id="contact-name"
              name="name"
              type="text"
              placeholder="Jane Smith"
              class="w-full min-h-[44px] px-4 py-3 rounded-xl bg-surface-input border border-border-default text-text-primary placeholder:text-text-tertiary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary/35 focus-visible:border-border-brand transition-colors duration-normal"
            />
          </div>

          <div>
            <label for="contact-email" class="block text-sm font-heading font-semibold text-text-primary mb-2">
              Work Email
            </label>
            <input
              id="contact-email"
              name="email"
              type="email"
              placeholder="jane@company.com"
              class="w-full min-h-[44px] px-4 py-3 rounded-xl bg-surface-input border border-border-default text-text-primary placeholder:text-text-tertiary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary/35 focus-visible:border-border-brand transition-colors duration-normal"
            />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="contact-company" class="block text-sm font-heading font-semibold text-text-primary mb-2">
              Company
            </label>
            <input
              id="contact-company"
              name="company"
              type="text"
              placeholder="Acme Retail"
              class="w-full min-h-[44px] px-4 py-3 rounded-xl bg-surface-input border border-border-default text-text-primary placeholder:text-text-tertiary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary/35 focus-visible:border-border-brand transition-colors duration-normal"
            />
          </div>

          <div>
            <label for="contact-volume-trigger" class="block text-sm font-heading font-semibold text-text-primary mb-2">
              Monthly Payment Volume
            </label>
            <div class="relative" data-select>
              <input id="contact-volume" name="volume" type="hidden" value="" />
              <button
                id="contact-volume-trigger"
                type="button"
                data-select-trigger
                class="w-full min-h-[44px] px-4 py-3 rounded-xl bg-surface-input border border-border-default text-text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary/35 focus-visible:border-border-brand transition-colors duration-normal cursor-pointer inline-flex items-center justify-between gap-3"
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-controls="contact-volume-options"
              >
                <span data-select-label class="text-text-tertiary">Select a range</span>
                <svg data-select-icon width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-secondary transition-transform duration-normal" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
              </button>

              <div
                id="contact-volume-options"
                data-select-menu
                role="listbox"
                class="hidden absolute z-popover mt-2 w-full rounded-xl bg-surface-card border border-border-default shadow-xl p-1"
              >
                <button type="button" role="option" data-select-option data-value="" data-label="Select a range" class="w-full text-left px-3 py-2.5 rounded-lg text-sm text-text-secondary hover:bg-surface-card-hover transition-colors duration-normal cursor-pointer">
                  Select a range
                </button>
                <button type="button" role="option" data-select-option data-value="under-50k" data-label="Under EUR 50k" class="w-full text-left px-3 py-2.5 rounded-lg text-sm text-text-primary hover:bg-surface-card-hover transition-colors duration-normal cursor-pointer">
                  Under EUR 50k
                </button>
                <button type="button" role="option" data-select-option data-value="50k-250k" data-label="EUR 50k - EUR 250k" class="w-full text-left px-3 py-2.5 rounded-lg text-sm text-text-primary hover:bg-surface-card-hover transition-colors duration-normal cursor-pointer">
                  EUR 50k - EUR 250k
                </button>
                <button type="button" role="option" data-select-option data-value="250k-1m" data-label="EUR 250k - EUR 1M" class="w-full text-left px-3 py-2.5 rounded-lg text-sm text-text-primary hover:bg-surface-card-hover transition-colors duration-normal cursor-pointer">
                  EUR 250k - EUR 1M
                </button>
                <button type="button" role="option" data-select-option data-value="over-1m" data-label="Over EUR 1M" class="w-full text-left px-3 py-2.5 rounded-lg text-sm text-text-primary hover:bg-surface-card-hover transition-colors duration-normal cursor-pointer">
                  Over EUR 1M
                </button>
              </div>
            </div>
          </div>
        </div>

        <div>
          <label for="contact-use-case-trigger" class="block text-sm font-heading font-semibold text-text-primary mb-2">
            Primary Use Case
          </label>
          <div class="relative" data-select>
            <input id="contact-use-case" name="useCase" type="hidden" value="" />
            <button
              id="contact-use-case-trigger"
              type="button"
              data-select-trigger
              class="w-full min-h-[44px] px-4 py-3 rounded-xl bg-surface-input border border-border-default text-text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary/35 focus-visible:border-border-brand transition-colors duration-normal cursor-pointer inline-flex items-center justify-between gap-3"
              aria-haspopup="listbox"
              aria-expanded="false"
              aria-controls="contact-use-case-options"
            >
              <span data-select-label class="text-text-tertiary">Select your use case</span>
              <svg data-select-icon width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-secondary transition-transform duration-normal" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
            </button>

            <div
              id="contact-use-case-options"
              data-select-menu
              role="listbox"
              class="hidden absolute z-popover mt-2 w-full rounded-xl bg-surface-card border border-border-default shadow-xl p-1"
            >
              <button type="button" role="option" data-select-option data-value="" data-label="Select your use case" class="w-full text-left px-3 py-2.5 rounded-lg text-sm text-text-secondary hover:bg-surface-card-hover transition-colors duration-normal cursor-pointer">
                Select your use case
              </button>
              <button type="button" role="option" data-select-option data-value="ecommerce" data-label="E-commerce checkout" class="w-full text-left px-3 py-2.5 rounded-lg text-sm text-text-primary hover:bg-surface-card-hover transition-colors duration-normal cursor-pointer">
                E-commerce checkout
              </button>
              <button type="button" role="option" data-select-option data-value="pos" data-label="In-store POS" class="w-full text-left px-3 py-2.5 rounded-lg text-sm text-text-primary hover:bg-surface-card-hover transition-colors duration-normal cursor-pointer">
                In-store POS
              </button>
              <button type="button" role="option" data-select-option data-value="hospitality" data-label="Hospitality and travel" class="w-full text-left px-3 py-2.5 rounded-lg text-sm text-text-primary hover:bg-surface-card-hover transition-colors duration-normal cursor-pointer">
                Hospitality and travel
              </button>
              <button type="button" role="option" data-select-option data-value="platform" data-label="Marketplace or platform" class="w-full text-left px-3 py-2.5 rounded-lg text-sm text-text-primary hover:bg-surface-card-hover transition-colors duration-normal cursor-pointer">
                Marketplace or platform
              </button>
            </div>
          </div>
        </div>

        <div>
          <label for="contact-message" class="block text-sm font-heading font-semibold text-text-primary mb-2">
            Message
          </label>
          <textarea
            id="contact-message"
            name="message"
            rows="5"
            placeholder="Tell us about your market, current setup, and goals."
            class="w-full px-4 py-3 rounded-xl bg-surface-input border border-border-default text-text-primary placeholder:text-text-tertiary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary/35 focus-visible:border-border-brand transition-colors duration-normal resize-y"
          ></textarea>
        </div>

        <div class="flex items-center justify-end pt-2">
          <button
            type="button"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-gradient-cta text-white font-heading font-semibold px-6 sm:px-8 py-3.5 min-h-[44px] rounded-xl shadow-glow-cta hover:shadow-glow-cta-hover transition-all duration-normal cursor-pointer text-base"
            aria-label="Send message"
          >
            Send Message
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 2 11 13"/><path d="m22 2-7 20-4-9-9-4Z"/></svg>
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  const selectWrappers = Array.from(document.querySelectorAll('[data-select]'));

  function resetWrapperLayer(wrapper) {
    wrapper.style.zIndex = '';

    const menu = wrapper.querySelector('[data-select-menu]');
    if (menu instanceof HTMLElement) {
      menu.style.zIndex = '';
    }
  }

  function elevateWrapperLayer(wrapper) {
    wrapper.style.zIndex = '9998';

    const menu = wrapper.querySelector('[data-select-menu]');
    if (menu instanceof HTMLElement) {
      menu.style.zIndex = '9999';
    }
  }

  function closeAllSelectMenus(except) {
    selectWrappers.forEach((wrapper) => {
      if (except && wrapper === except) {
        return;
      }

      const trigger = wrapper.querySelector('[data-select-trigger]');
      const menu = wrapper.querySelector('[data-select-menu]');
      const icon = wrapper.querySelector('[data-select-icon]');

      menu?.classList.add('hidden');
      trigger?.setAttribute('aria-expanded', 'false');
      icon?.classList.remove('rotate-180');
      resetWrapperLayer(wrapper);
    });
  }

  selectWrappers.forEach((wrapper) => {
    const trigger = wrapper.querySelector('[data-select-trigger]');
    const label = wrapper.querySelector('[data-select-label]');
    const menu = wrapper.querySelector('[data-select-menu]');
    const icon = wrapper.querySelector('[data-select-icon]');
    const hiddenInput = wrapper.querySelector('input[type="hidden"]');
    const options = Array.from(wrapper.querySelectorAll('[data-select-option]'));

    trigger?.addEventListener('click', () => {
      const isOpen = !menu?.classList.contains('hidden');

      closeAllSelectMenus(wrapper);

      if (!isOpen) {
        elevateWrapperLayer(wrapper);
        menu?.classList.remove('hidden');
        trigger?.setAttribute('aria-expanded', 'true');
        icon?.classList.add('rotate-180');
      } else {
        resetWrapperLayer(wrapper);
      }
    });

    options.forEach((option) => {
      option.addEventListener('click', () => {
        const value = option.getAttribute('data-value') || '';
        const nextLabel = option.getAttribute('data-label') || '';

        if (hiddenInput instanceof HTMLInputElement) {
          hiddenInput.value = value;
        }

        if (label) {
          label.textContent = nextLabel;
          label.classList.toggle('text-text-tertiary', value === '');
          label.classList.toggle('text-text-primary', value !== '');
        }

        closeAllSelectMenus();
      });
    });
  });

  document.addEventListener('click', (event) => {
    const target = event.target;

    if (!(target instanceof Element)) {
      return;
    }

    if (!target.closest('[data-select]')) {
      closeAllSelectMenus();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeAllSelectMenus();
    }
  });
</script>
