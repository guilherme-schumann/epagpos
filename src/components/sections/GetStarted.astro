<section id="get-started" class="relative py-20 sm:py-24 md:py-32 overflow-hidden">
  <!-- Background glow -->
  <div class="absolute inset-0 bg-gradient-glow-blue pointer-events-none"></div>
  <div class="orb-blue absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] sm:w-[700px] sm:h-[700px] md:w-[1000px] md:h-[1000px] opacity-40"></div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
    <!-- Section header -->
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-xs text-brand-primary mb-6">
      Get Started
    </div>

    <h2 class="text-2xl sm:text-3xl md:text-5xl font-heading font-bold leading-tight mb-6">
      Ready to Unlock<br />
      <span class="text-gradient-brand">Latin American Revenue?</span>
    </h2>

    <p class="text-base sm:text-lg text-text-secondary leading-relaxed mb-4">
      Start accepting Pix and local payments today.
    </p>
    <p class="text-text-secondary mb-8 sm:mb-10">
      No long contracts. No complex integration. Just new revenue.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4">
      <a
        href="#"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-gradient-cta text-white font-heading font-semibold px-6 sm:px-8 py-3.5 min-h-[44px] rounded-xl shadow-glow-cta hover:shadow-glow-cta-hover transition-all duration-normal cursor-pointer text-base sm:text-lg"
      >
        Talk to Sales
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a
        href="#"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-surface-card border border-border-default text-text-primary font-heading font-semibold px-6 sm:px-8 py-3.5 min-h-[44px] rounded-xl hover:bg-surface-card-hover hover:border-border-medium transition-all duration-normal cursor-pointer text-base sm:text-lg"
      >
        Request a Demo
      </a>
    </div>
  </div>
</section>
