---
---

<section class="relative overflow-hidden pt-32 pb-24 md:pt-44 md:pb-32">
  <!-- Background decorations -->
  <div class="orb-blue absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] sm:w-[600px] sm:h-[600px] md:w-[800px] md:h-[800px]"></div>
  <div class="orb-cyan absolute bottom-0 right-0 translate-x-1/3"></div>
  <div class="bg-dot-pattern absolute inset-0 pointer-events-none"></div>

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-sm text-brand-primary mb-8">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-primary" aria-hidden="true"><path d="m13 2 5.464 5.464a1 1 0 0 1 0 1.414L7.636 19.707a1 1 0 0 1-1.414 0L2 15.464"/><path d="m8 10 4 4"/><path d="m22 2-8.293 8.293"/></svg>
      Cross-Border Payments Made Simple
    </div>

    <!-- Headline -->
    <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-7xl font-heading font-bold leading-tight tracking-tight">
      Accept Pix everywhere<br />
      <span class="text-gradient-brand">your customers pay.</span>
    </h1>

    <!-- Subheadline -->
    <p class="mt-6 max-w-3xl mx-auto text-lg md:text-xl text-text-secondary leading-relaxed">
      From POS terminals to mobile wallets to self-checkout kiosks — deliver one seamless, frictionless payment experience. Accept Pix and Latin America's most popular payment methods with a single, unified integration.
    </p>

    <!-- CTAs -->
    <div class="mt-8 sm:mt-10 flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4">
      <a
        href="#get-started"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-gradient-cta text-white font-heading font-semibold px-6 sm:px-8 py-3.5 min-h-[44px] rounded-xl shadow-glow-cta hover:shadow-glow-cta-hover transition-all duration-normal cursor-pointer text-base sm:text-lg"
      >
        Start Accepting Pix Today
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a
        href="#how-it-works"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-surface-card border border-border-default text-text-primary font-heading font-semibold px-6 sm:px-8 py-3.5 min-h-[44px] rounded-xl hover:bg-surface-card-hover hover:border-border-medium transition-all duration-normal cursor-pointer text-base sm:text-lg"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="6 3 20 12 6 21 6 3"/></svg>
        See How It Works
      </a>
    </div>

    <!-- Trust indicators -->
    <div class="mt-16 flex flex-wrap items-center justify-center gap-x-8 gap-y-4 text-sm text-text-tertiary">
      <div class="flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-status-success" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
        Zero chargebacks
      </div>
      <div class="flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-status-success" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
        Instant settlement
      </div>
      <div class="flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-status-success" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
        65% lower fees
      </div>
      <div class="flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-status-success" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
        Single integration
      </div>
    </div>
  </div>
</section>
