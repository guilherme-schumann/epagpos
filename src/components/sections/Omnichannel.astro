---
const channels = [
  {
    title: 'POS Terminals',
    description: 'In-store QR code payments at point of sale',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2"/><line x1="8" x2="16" y1="6" y2="6"/><line x1="16" x2="16" y1="14" y2="18"/><path d="M12 18h.01"/><path d="M8 18h.01"/><path d="M12 14h.01"/><path d="M8 14h.01"/></svg>',
  },
  {
    title: 'Self-Checkout',
    description: 'Unattended kiosks with dynamic QR generation',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>',
  },
  {
    title: 'Mobile',
    description: 'Tap-to-pay and mobile wallet integration',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>',
  },
  {
    title: 'E-Commerce',
    description: 'Online checkout with instant confirmation',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>',
  },
];
---

<section id="omnichannel" class="relative py-16 sm:py-24 md:py-32 bg-surface-raised">
  <div class="bg-line-pattern absolute inset-0 pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-10 sm:mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-primary/10 border border-brand-primary/20 text-xs text-brand-primary mb-6">
        Omnichannel
      </div>
      <h2 class="text-2xl sm:text-3xl md:text-5xl font-heading font-bold leading-tight">
        One Integration. Every Channel.<br />
        <span class="text-gradient-brand">Total Coverage.</span>
      </h2>
      <p class="mt-6 text-lg text-text-secondary leading-relaxed">
        Your customers don't think in channels — and neither should your payments. Deploy Pix and local APMs across every touchpoint from a single integration.
      </p>
    </div>

    <!-- Channel cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {channels.map((channel) => (
        <div class="glass-card p-6 rounded-2xl text-center group hover:border-brand-primary/20 hover:shadow-glow-sm transition-all duration-normal cursor-default">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-brand-primary/10 text-brand-primary mb-5 group-hover:shadow-glow-sm transition-shadow duration-normal" set:html={channel.icon} />
          <h3 class="text-lg font-heading font-semibold text-text-primary mb-2">{channel.title}</h3>
          <p class="text-text-secondary text-sm">{channel.description}</p>
        </div>
      ))}
    </div>

    <!-- Tagline -->
    <p class="mt-12 text-center text-xl font-heading font-semibold text-text-accent italic">
      One solution. One experience. Everywhere your customer is.
    </p>
  </div>
</section>
